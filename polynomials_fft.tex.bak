\section*{FFT Beispiel Schritt für Schritt}

\subsection*{Algorithmus (FFT)}

\begin{verbatim}
def fft(p):
    n = len(p)
    if n == 1:
        return p

    p_e = p[0::2]
    p_o = p[1::2]

    y_e = fft(p_e)
    y_o = fft(p_o)

    y = [0]*n
    w = exp(2*pi*i / n)
    w_i = 1

    for j in range(n//2):
        y[j] = y_e[j] + w_i * y_o[j]
        y[j + n//2] = y_e[j] - w_i * y_o[j]
        w_i *= w

    return y
\end{verbatim}

Gegeben sei das Polynom mit Koeffizienten:
\[
P = [-1,-1,1,-5,0,-4,2,3]
\]

\subsection*{1. Erste Aufteilung}

\[
P_e = [-1,1,0,2], \quad P_o = [-1,-5,-4,3]
\]

\[
\text{fft}(P) = \text{combine}(\text{fft}(P_e), \text{fft}(P_o))
\]

\subsection*{2. Linker Teil: $\text{fft}(P_e)$}

\[
P_e = [-1,1,0,2]
\]

Aufteilung:
\[
P_{ee} = [-1,0], \quad P_{eo} = [1,2]
\]

\subsubsection*{2.1 $\text{fft}([-1,0])$}

\[
[-1] \to [-1], \quad [0] \to [0]
\]

\[
\text{fft}([-1,0]) = [-1+0, -1-0] = [-1,-1]
\]

\subsubsection*{2.2 $\text{fft}([1,2])$}

\[
[1] \to [1], \quad [2] \to [2]
\]

\[
\text{fft}([1,2]) = [1+2, 1-2] = [3,-1]
\]

\subsubsection*{2.3 Kombination ($n=4$, $w=i$)}

\[
y_e = [-1,-1], \quad y_o = [3,-1]
\]

\[
\begin{aligned}
y[0] &= -1 + 3 = 2 \\
y[2] &= -1 - 3 = -4 \\
y[1] &= -1 + i(-1) = -1 - i \\
y[3] &= -1 - i(-1) = -1 + i
\end{aligned}
\]

\[
\text{fft}(P_e) = [2,\,-1-i,\,-4,\,-1+i]
\]

\subsection*{3. Rechter Teil: $\text{fft}(P_o)$}

\[
P_o = [-1,-5,-4,3]
\]

Aufteilung:
\[
P_{oe} = [-1,-4], \quad P_{oo} = [-5,3]
\]

\subsubsection*{3.1 $\text{fft}([-1,-4])$}

\[
[-1] \to [-1], \quad [-4] \to [-4]
\]

\[
\text{fft}([-1,-4]) = [-1-4,\,-1+4] = [-5,3]
\]

\subsubsection*{3.2 $\text{fft}([-5,3])$}

\[
[-5] \to [-5], \quad [3] \to [3]
\]

\[
\text{fft}([-5,3]) = [-5+3,\,-5-3] = [-2,-8]
\]

\subsubsection*{3.3 Kombination}

\[
y_e = [-5,3], \quad y_o = [-2,-8]
\]

\[
\begin{aligned}
y[0] &= -5 -2 = -7 \\
y[2] &= -5 +2 = -3 \\
y[1] &= 3 + i(-8) = 3 - 8i \\
y[3] &= 3 - i(-8) = 3 + 8i
\end{aligned}
\]

\[
\text{fft}(P_o) = [-7,\;3-8i,\;-3,\;3+8i]
\]

\subsection*{4. Finale Kombination ($n=8$)}

\[
Y_e = [2,\,-1-i,\,-4,\,-1+i]
\]
\[
Y_o = [-7,\;3-8i,\;-3,\;3+8i]
\]

\[
\omega = e^{2\pi i / 8}
\]

\subsubsection*{4.1 $j=0$}

\[
Y[0] = 2 - 7 = -5
\]
\[
Y[4] = 2 + 7 = 9
\]

\subsubsection*{4.2 $j=1$}

\[
\omega = \frac{1+i}{\sqrt{2}}
\]

\[
(1+i)(3-8i) = 11 - 5i
\]

\[
Y[1] = -1 - i + \frac{11-5i}{\sqrt{2}}
\]
\[
Y[5] = -1 - i - \frac{11-5i}{\sqrt{2}}
\]

\subsubsection*{4.3 $j=2$}

\[
\omega^2 = i
\]

\[
Y[2] = -4 - 3i
\]
\[
Y[6] = -4 + 3i
\]

\subsubsection*{4.4 $j=3$}

\[
\omega^3 = \frac{-1+i}{\sqrt{2}}
\]

\[
(-1+i)(3+8i) = -11 - 5i
\]

\[
Y[3] = -1 + i + \frac{-11-5i}{\sqrt{2}}
\]
\[
Y[7] = -1 + i - \frac{-11-5i}{\sqrt{2}}
\]

\subsection*{5. Ergebnis}

\[
\boxed{
\begin{aligned}
[-5,\;&-1-i+\tfrac{11-5i}{\sqrt{2}},\;-4-3i,\;-1+i+\tfrac{-11-5i}{\sqrt{2}},\\
&9,\;-1-i-\tfrac{11-5i}{\sqrt{2}},\;-4+3i,\;-1+i-\tfrac{-11-5i}{\sqrt{2}}]
\end{aligned}
}
\]